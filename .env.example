# Shared project defaults. Copy to .env, then keep machine-specific secrets in .env.local.
PROJECT_NAME="Global Intelligence Briefing"
GCP_PROJECT_ID="podcast-project-491300"
FIRESTORE_DATABASE="(default)"
BRIEFING_TIMEZONE="Australia/Brisbane"
ENVIRONMENT="dev"

# Docs/Drive output.
# Leave empty when using personal OAuth and writing to the user's My Drive root.
# Set to a folder ID when writing to a specific My Drive folder or Shared Drive folder.
DRIVE_OUTPUT_FOLDER_ID=""

# Workspace auth mode:
# - oauth: Google Docs/Drive use the signed-in user's OAuth token.
# - default: Google Docs/Drive use GOOGLE_APPLICATION_CREDENTIALS / ADC.
GOOGLE_WORKSPACE_AUTH_MODE="oauth"
GOOGLE_OAUTH_CLIENT_SECRET_FILE="client_secret.json"
GOOGLE_OAUTH_TOKEN_FILE=".secrets/google_oauth_token.json"

# RSS source registry in Google Sheets.
GOOGLE_SHEET_ID=""
GOOGLE_SHEET_RANGE="'RSS List'!A:J"
