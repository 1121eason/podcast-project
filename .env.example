# Shared project defaults. Copy to .env, then keep machine-specific secrets in .env.local.
PROJECT_NAME="Global Intelligence Briefing"
GCP_PROJECT_ID="podcast-project-491300"
FIRESTORE_DATABASE="(default)"
BRIEFING_TIMEZONE="Australia/Brisbane"
ENVIRONMENT="dev"
VERTEX_LOCATION="us-central1"

# Signal Intelligence v2 model policy.
JUDGEMENT_PROVIDER="gemini"
JUDGEMENT_MODEL_GEMINI="gemini-2.5-flash"
JUDGEMENT_ESCALATION_MODEL_GEMINI="gemini-2.5-pro"
IMPACT_PROVIDER="gemini"
IMPACT_MODEL_GEMINI="gemini-2.5-flash"
IMPACT_ESCALATION_MODEL_GEMINI="gemini-2.5-pro"
BRIEFING_PROVIDER="gemini"
BRIEFING_MODEL_GEMINI="gemini-2.5-pro"
PODCAST_SCRIPT_PROVIDER="gemini"
PODCAST_SCRIPT_MODEL_GEMINI="gemini-2.5-pro"
CANONICALIZATION_MODEL_GEMINI="gemini-2.5-flash"
MATCH_ADJUDICATION_MODEL_GEMINI="gemini-2.5-pro"
DAILY_CONSOLIDATION_MODEL_GEMINI="gemini-2.5-pro"
EMBEDDING_MODEL="gemini-embedding-001"
EMBEDDING_FALLBACK_MODEL="text-embedding-004"
SIGNAL_MATCH_AUTO_THRESHOLD=0.86
SIGNAL_MATCH_REVIEW_THRESHOLD=0.76
SIGNAL_MATCH_GENERIC_AUTO_THRESHOLD=0.90
CENTROID_DECAY=0.85
STORY_THREAD_LOOKBACK_DAYS=30

# Docs/Drive output.
# Leave empty when using personal OAuth and writing to the user's My Drive root.
# Set to a folder ID when writing to a specific My Drive folder or Shared Drive folder.
DRIVE_OUTPUT_FOLDER_ID=""

# Podcast audio output.
GCS_AUDIO_BUCKET=""
PODCAST_TTS_VOICE="cmn-TW-Wavenet-B"
PODCAST_TTS_LANGUAGE_CODE="cmn-TW"
PODCAST_TTS_LOCATION="global"
PODCAST_TTS_TIMEOUT_SECONDS=1800

# Workspace auth mode:
# - oauth: Google Docs/Drive use the signed-in user's OAuth token.
# - default: Google Docs/Drive use GOOGLE_APPLICATION_CREDENTIALS / ADC.
GOOGLE_WORKSPACE_AUTH_MODE="oauth"
GOOGLE_OAUTH_CLIENT_SECRET_FILE="client_secret.json"
GOOGLE_OAUTH_TOKEN_FILE=".secrets/google_oauth_token.json"

# RSS source registry in Google Sheets.
GOOGLE_SHEET_ID=""
GOOGLE_SHEET_RANGE="'RSS List'!A:J"
