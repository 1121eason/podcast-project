# Local-only secrets and absolute paths. Copy to .env.local.
# This file is safe to commit; .env.local is ignored.

# Required for Firestore / Vertex AI / Text-to-Speech when running locally.
# Move the service account JSON outside the repo first, then point here.
GOOGLE_APPLICATION_CREDENTIALS="/Users/eason/.config/signal-brief/service-account.json"

# Required for mutating API endpoints: start, poll, approve.
ADMIN_TOKEN="replace-with-a-long-local-token"

# Optional. Use only if you call Gemini through AI Studio API key instead of Vertex AI.
# GEMINI_API_KEY="replace-with-your-gemini-api-key"

# Required for /sources/sheets/sync.
# Use the spreadsheet ID from the Google Sheet URL.
GOOGLE_SHEET_ID="replace-with-your-rss-source-sheet-id"
GOOGLE_SHEET_RANGE="'RSS List'!A:J"
