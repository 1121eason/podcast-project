# Local-only secrets and absolute paths. Copy to .env.local.
# This file is safe to commit; .env.local is ignored.

# Required for Firestore / Vertex AI / Text-to-Speech when running locally.
# Move the service account JSON outside the repo first, then point here.
GOOGLE_APPLICATION_CREDENTIALS="/Users/eason/.config/signal-brief/service-account.json"

# Required for mutating API endpoints: start, poll, approve.
ADMIN_TOKEN="replace-with-a-long-local-token"

# Optional. Use only if you call Gemini through AI Studio API key instead of Vertex AI.
# GEMINI_API_KEY="replace-with-your-gemini-api-key"

# Required for /sources/sheets/sync.
# Use the spreadsheet ID from the Google Sheet URL.
GOOGLE_SHEET_ID="replace-with-your-rss-source-sheet-id"
GOOGLE_SHEET_RANGE="'RSS List'!A:J"

# Required for Phase 5 podcast MP3 output.
GCS_AUDIO_BUCKET="replace-with-your-podcast-audio-bucket"

OPENAI_API_KEY=""
JUDGEMENT_PROVIDER="gemini"
JUDGEMENT_MODEL_OPENAI="gpt-5-mini"
JUDGEMENT_MODEL_GEMINI="gemini-2.5-flash"
JUDGEMENT_ESCALATION_MODEL_GEMINI="gemini-2.5-pro"
IMPACT_PROVIDER="gemini"
IMPACT_MODEL_OPENAI="gpt-5-mini"
IMPACT_MODEL_GEMINI="gemini-2.5-flash"
IMPACT_ESCALATION_MODEL_GEMINI="gemini-2.5-pro"
BRIEFING_PROVIDER="gemini"
BRIEFING_MODEL_OPENAI="gpt-5"
BRIEFING_MODEL_GEMINI="gemini-2.5-pro"
PODCAST_SCRIPT_PROVIDER="gemini"
PODCAST_SCRIPT_MODEL_OPENAI="gpt-5"
PODCAST_SCRIPT_MODEL_GEMINI="gemini-2.5-pro"
CANONICALIZATION_MODEL_GEMINI="gemini-2.5-flash"
MATCH_ADJUDICATION_MODEL_GEMINI="gemini-2.5-pro"
DAILY_CONSOLIDATION_MODEL_GEMINI="gemini-2.5-pro"
EMBEDDING_MODEL="gemini-embedding-001"
EMBEDDING_FALLBACK_MODEL="text-embedding-004"
SIGNAL_MATCH_AUTO_THRESHOLD=0.86
SIGNAL_MATCH_REVIEW_THRESHOLD=0.76
SIGNAL_MATCH_GENERIC_AUTO_THRESHOLD=0.90
CENTROID_DECAY=0.85
STORY_THREAD_LOOKBACK_DAYS=30
